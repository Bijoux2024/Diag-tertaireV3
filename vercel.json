{
  "rewrites": [
    { "source": "/blog", "destination": "https://diag-tertiaire-blog.vercel.app/" },
    { "source": "/blog/", "destination": "https://diag-tertiaire-blog.vercel.app/" },
    { "source": "/blog/(.*)", "destination": "https://diag-tertiaire-blog.vercel.app/$1" },
    { "source": "/diagnostic", "destination": "/" },
    { "source": "/exemple-rapport", "destination": "/exemple-rapport.html" },
    { "source": "/espace-professionnel", "destination": "/espace-professionnel.html" },
    { "source": "/index.saaspro.html", "destination": "/espace-professionnel.html" }
  ],
  "headers": [
    {
      "source": "/blog(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    },
    {
      "source": "/(.*\\.xml)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/partenaire.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/espace-professionnel.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/diagtertiaire-pro-alpha.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/public-report-print.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), accelerometer=(), gyroscope=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://unpkg.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://code.iconify.design; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.tailwindcss.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co https://*.supabase.io https://data.geopf.fr https://panoramax.ign.fr; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self';" }
      ]
    }
  ]
}
